# ─────────────────────────────────────────────────────────────────────────────
# osu!helper — Environment Variable Template
#
# HOW TO USE:
#   Local development:  copy this file to ".env" and fill in your values.
#                       ".env" is in .gitignore so it will NEVER be committed.
#   Railway (hosted):   paste each variable into Railway → Variables panel.
#                       NEVER put real values in this file — it IS committed.
# ─────────────────────────────────────────────────────────────────────────────

# Set to 1 when deploying publicly (Railway, Render, Fly.io, etc.)
OAUTH_MODE=1

# Your osu! OAuth application credentials.
# Create one at: https://osu.ppy.sh/home/account/edit#oauth
# Set Callback URL to: https://YOUR-APP.railway.app/auth/callback
OSU_CLIENT_ID=YOUR_CLIENT_ID_HERE
OSU_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
OSU_REDIRECT_URI=https://YOUR-APP.railway.app/auth/callback

# Flask session secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use a DIFFERENT value for every deployment. Never reuse.
SECRET_KEY=GENERATE_A_RANDOM_64_CHAR_HEX_STRING_HERE
