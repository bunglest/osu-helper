# ─────────────────────────────────────
# osu!helper — Railway environment vars
# Copy to Railway → Variables panel
# ─────────────────────────────────────

# Enable osu! OAuth login for visitors
OAUTH_MODE=1

# Your osu! OAuth application credentials
# Create one at: https://osu.ppy.sh/home/account/edit#oauth
# Set Callback URL to: https://YOUR-APP.railway.app/auth/callback
OSU_CLIENT_ID=49796
OSU_CLIENT_SECRET=your_client_secret_here
OSU_REDIRECT_URI=https://YOUR-APP.railway.app/auth/callback

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_random_secret_string
